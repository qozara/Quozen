{
  "name": "quozen",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev --workspace=@quozen/webapp",
    "dev:api": "npm run dev --workspace=@quozen/api",
    "dev:ai": "npm run dev --workspace=@quozen/ai-proxy",
    "build": "npm run build --workspaces --if-present",
    "cli": "npm run start --workspace=@quozen/cli",
    "preview": "npm run preview --workspace=@quozen/webapp",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:core:all": "npm run test:all --workspace=@quozen/core",
    "test:core:all:non-interactive": "npm run test:all:non-interactive --workspace=@quozen/core",
    "test:core:smoke-test": "npm run test:ai:live-smoke-test --workspace=@quozen/core",
    "test:web:e2e": "npm run test:e2e --workspace=@quozen/webapp",
    "test:web:watch": "npm run test:watch --workspace=@quozen/webapp",
    "test:all:non-interactive": "node scripts/run-all-tests.js --non-interactive",
    "test:all": "node scripts/run-all-tests.js",
    "predeploy": "npm run test:all:non-interactive && npm run build",
    "deploy:api:vercel": "npm run build --workspaces --if-present && vercel deploy",
    "deploy:api:cf": "npm run build --workspaces --if-present && npm run deploy --workspace=@quozen/api",
    "deploy:ai:cf": "npm run build --workspaces --if-present && npm run deploy --workspace=@quozen/ai-proxy"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "typescript": "5.6.3",
    "wrangler": "^4.68.0"
  }
}