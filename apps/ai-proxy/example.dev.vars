# --- SHARED CONFIGURATION ---
KMS_SECRET="your-local-32-byte-secret-for-dev"
NODE_ENV=development
AI_PROVIDER=google # Options: 'google', 'ollama'

# --- RATE LIMITING (CLOUD ONLY) ---
AI_RATE_LIMIT_REQUESTS=20
AI_RATE_LIMIT_WINDOW="1 d"
# KV_REST_API_URL="your-kv-url"      # Required for rate limiting
# KV_REST_API_TOKEN="your-kv-token"  # Required for rate limiting

# --- GOOGLE PROVIDER CONFIG ---
# Used when AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=your-api-key
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.0-flash

# --- OLLAMA PROVIDER CONFIG ---
# Used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_AI_MODEL=qwen3:0.6b
